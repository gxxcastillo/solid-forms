{
  "name": "@gxxc/solid-forms-repo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Solid.js forms",
  "repository": {
    "type": "git",
    "url": "https://github.com/gxxcastillo/solid-forms"
  },
  "homepage": "https://gxxcastillo.github.io/solid-forms/",
  "scripts": {
    "clean": "pnpm clean:modules && pnpm clean:dist",
    "clean:modules": "find . -name 'node_modules' -print -type d -prune -exec rm -rf '{}' + ",
    "clean:dist": "find . -name 'dist' -print -type d -prune -exec rm -rf '{}' + ",
    "lint": "pnpm moon :lint",
    "types": "pnpm moon :types",
    "test": "pnpm moon :test",
    "a11y": "pnpm moon :a11y",
    "coverage": "pnpm moon :coverage",
    "format": "pnpm moon :format",
    "bump": "pnpm changeset version",
    "prepublishOnly": "node --eval \"console.error('\\nRun pnpm run publish instead.\\n'); process.exit(1)\"",
    "publish": "pnpm --filter @gxxc/solid-forms publish"
  },
  "keywords": [
    "solid-js",
    "forms"
  ],
  "author": "gxxcastillo",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/cli": "^2.27.7",
    "@moonrepo/cli": "^1.27.6",
    "@playwright/test": "^1.61.1",
    "@solidjs/testing-library": "^0.8.10",
    "@stylistic/eslint-plugin": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "@vitest/coverage-v8": "2.1.9",
    "eslint": "^8.56.0",
    "eslint-config-moon": "^3.1.2",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.3.3",
    "typescript": "5.4.2",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": "22.12.0"
  }
}
