{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-types",
    "emitDeclarationOnly": true,
    "types": ["node", "vite/client"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "paths": {
      "@gxxc/solid-forms/styles.css": ["../../packages/solid-forms/src/index.ts"],
      "@gxxc/solid-forms/themes/*": ["../../packages/solid-forms/themes/*"],
      "@gxxc/solid-forms-examples": ["../../packages/examples/src/index.ts"],
      "@gxxc/solid-forms": ["../../packages/solid-forms/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "playwright.config.ts", "vite.config.ts"],
  "references": [
    {
      "path": "../../packages/solid-forms"
    },
    {
      "path": "../../packages/examples"
    }
  ]
}
