{
  "name": "@gxxc/solid-forms",
  "version": "0.1.1",
  "type": "module",
  "description": "Solid.js forms",
  "repository": {
    "type": "git",
    "url": "https://github.com/gxxcastillo/solid-forms",
    "directory": "packages/solid-forms"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "development": "./src/index.ts"
    },
    "./styles.css": "./dist/style.css",
    "./themes/base.css": {
      "development": "./themes/base.css",
      "default": "./dist/themes/base.css"
    },
    "./themes/minimal.css": {
      "development": "./themes/minimal.css",
      "default": "./dist/themes/minimal.css"
    },
    "./themes/midnight.css": {
      "development": "./themes/midnight.css",
      "default": "./dist/themes/midnight.css"
    },
    "./themes/neobrutalist.css": {
      "development": "./themes/neobrutalist.css",
      "default": "./dist/themes/neobrutalist.css"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./styles.css": "./dist/style.css",
      "./themes/base.css": "./dist/themes/base.css",
      "./themes/minimal.css": "./dist/themes/minimal.css",
      "./themes/midnight.css": "./dist/themes/midnight.css",
      "./themes/neobrutalist.css": "./dist/themes/neobrutalist.css"
    }
  },
  "scripts": {
    "prepublishOnly": "vite build",
    "postpublish": "git tag @gxxc/solid-forms@$(node -p \"require('./package.json').version\") && git push origin @gxxc/solid-forms@$(node -p \"require('./package.json').version\")"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@gxxc/solid-forms-fields": "workspace:^",
    "@gxxc/solid-forms-form": "workspace:^",
    "@gxxc/solid-forms-state": "workspace:^",
    "type-fest": "^4.24.0",
    "typescript": "5.4.2",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.1",
    "vite-plugin-solid": "^2.3.0"
  },
  "peerDependencies": {
    "solid-js": "^1.8.20"
  }
}
